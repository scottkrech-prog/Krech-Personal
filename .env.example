# Email recipient for Jerry / business copy
OWNER_EMAIL=jerry@example.com

# Optional branded from address. Usually the same as SMTP_USER or an authenticated domain address.
FROM_EMAIL=no-reply@cltpropertydetailing.com

# SMTP settings from Gmail/Google Workspace, Namecheap, GoDaddy, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=username@example.com
SMTP_PASS=your-smtp-password-or-app-password
